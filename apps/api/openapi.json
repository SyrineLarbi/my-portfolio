{
  "openapi": "3.0.0",
  "paths": {
    "/api/contact": {
      "post": {
        "operationId": "ContactController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContactDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Submit the contact form (queued, emailed asynchronously via BullMQ + Resend)",
        "tags": [
          "contact"
        ]
      }
    },
    "/api/cv": {
      "get": {
        "operationId": "CvController_download",
        "parameters": [
          {
            "name": "persona",
            "required": false,
            "in": "query",
            "schema": {}
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Download the CV PDF (logs the download to CvDownload first)",
        "tags": [
          "cv"
        ]
      }
    },
    "/api/cv/count": {
      "get": {
        "operationId": "CvController_count",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Public counter — total CV downloads (used by the Download CV button)",
        "tags": [
          "cv"
        ]
      }
    },
    "/api/track": {
      "post": {
        "operationId": "AnalyticsController_track",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Record a page view (path + persona + visitorId for unique-visitor metrics)",
        "tags": [
          "track"
        ]
      }
    },
    "/api/admin/login": {
      "post": {
        "operationId": "AdminController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Sign in (sets the portfolio_admin JWT cookie on success)",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/admin/logout": {
      "post": {
        "operationId": "AdminController_logout",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Sign out (clears the portfolio_admin cookie)",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/admin/messages": {
      "get": {
        "operationId": "AdminController_messages",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "portfolio_admin": []
          }
        ],
        "summary": "List recent contact submissions (newest first, default 50)",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/admin/downloads": {
      "get": {
        "operationId": "AdminController_downloads",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "portfolio_admin": []
          }
        ],
        "summary": "List recent CV downloads (newest first, default 50)",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/admin/views": {
      "get": {
        "operationId": "AdminController_views",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "portfolio_admin": []
          }
        ],
        "summary": "Persona breakdown — total page views per persona over the last 30 days",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Liveness + DB round-trip (used by Railway health checks)",
        "tags": [
          "health"
        ]
      }
    }
  },
  "info": {
    "title": "Syrine Portfolio API",
    "description": "Backend for the portfolio site (contact, CV, analytics, admin)",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "portfolio_admin"
      }
    },
    "schemas": {
      "CreateContactDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          },
          "email": {
            "type": "string",
            "maxLength": 255,
            "format": "email"
          },
          "message": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2000
          },
          "persona": {
            "type": "string",
            "enum": [
              "fullstack",
              "data",
              "manager"
            ]
          }
        },
        "required": [
          "name",
          "email",
          "message"
        ]
      },
      "TrackDto": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "maxLength": 200
          },
          "persona": {
            "type": "string",
            "enum": [
              "fullstack",
              "data",
              "manager"
            ]
          },
          "visitorId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "path"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}